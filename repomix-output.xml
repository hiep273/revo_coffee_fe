              >
                ĐẶT HÀNG NGAY
              </button>
              <div className="flex items-center justify-center gap-2 mt-4 text-primary/50 font-nunito text-sm">
                <Info size={16} /> Chúng tôi cam kết bảo mật thông tin của bạn
              </div>
            </div>
          </div>

        </div>
      </div>
    </div>
  );
}
